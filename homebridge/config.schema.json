{
  "pluginAlias": "Digital Intercom",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "required": ["allowedCards"],
    "additionalProperties": false,
    "properties": {
      "allowedCards": {
        "title": "Allowed Cards",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "hash": {
              "title": "Card Number",
              "type": "string"
            },
            "description": {
              "title": "Description",
              "type": "string"
            }
          }
        }
      },
      "allowedDigitalIds": {
        "title": "Allowed Digital IDs",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "givenName": {
              "title": "Given Name",
              "type": "string"
            },
            "familyName": {
              "title": "Family Name",
              "type": "string"
            },
            "birthDate": {
              "title": "Birth Date",
              "description": "In the format YYYY-MM-DD",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        }
      }
    }
  }
}
